# Supabase (optional — game runs fully without it via local persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Persistence backend: "local" (default) or "supabase"
NEXT_PUBLIC_PERSISTENCE=local

# Server-authoritative API proxy. Keep disabled until Supabase Auth/backend flow is ready.
SERVER_AUTHORITATIVE_API_ENABLED=false
