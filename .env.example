# Supabase opcional. El juego puede ejecutarse con persistencia local en alpha.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend de persistencia: "local" por defecto o "supabase".
NEXT_PUBLIC_PERSISTENCE=local

# Marco visual tipo canvas para rutas inmersivas. "false" permite rollback rapido si no convence.
NEXT_PUBLIC_GAME_FIXED_STAGE=true

# Proxy de operaciones autoritativas. Mantener desactivado si Auth/backend no esta listo.
SERVER_AUTHORITATIVE_API_ENABLED=false
AUTHORITATIVE_RATE_LIMIT_BACKEND=memory

# Observabilidad de rechazos/fallos del proxy autoritativo: "console", "disabled" o "webhook".
AUTHORITATIVE_SECURITY_EVENT_SINK=console
AUTHORITATIVE_SECURITY_EVENT_WEBHOOK_URL=
AUTHORITATIVE_SECURITY_EVENT_WEBHOOK_TIMEOUT_MS=1500
