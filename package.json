{
  "name": "duskkeep-fronts",
  "version": "0.32.35",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "check:full": "npm run check && npm run test && npm run build",
    "audit:assets": "node scripts/audit-public-assets.mjs",
    "audit:asset-refs": "node scripts/audit-public-asset-refs.mjs",
    "audit:build": "node scripts/audit-build-output.mjs",
    "audit:high": "npm audit --audit-level=high",
    "check:performance": "node scripts/check-performance-budget.mjs",
    "smoke:authoritative-api": "node scripts/smoke-authoritative-api.mjs",
    "smoke:supabase:guest": "npx supabase db query --local --file supabase/smoke-tests/auth_guest_provisioning.sql --output table",
    "smoke:supabase:snapshot": "npx supabase db query --local --file supabase/smoke-tests/player_snapshot_rpc.sql --output table",
    "smoke:supabase:guest-upgrade": "node scripts/smoke-supabase-anonymous-upgrade.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:reset": "node scripts/reset.mjs",
    "screenshots": "node scripts/capture-screens.mjs",
    "screenshots:auto": "node scripts/capture-screens.mjs --start-server",
    "audio:sfx": "node scripts/audio/generate-elevenlabs-sfx.mjs",
    "audio:music": "node scripts/audio/generate-elevenlabs-music.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "clsx": "2.1.1",
    "next": "^16.2.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "2.3.0",
    "zod": "3.23.8",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.5.0",
    "eslint": "8.57.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.10",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5",
    "vitest": "^4.1.5"
  }
}
