{
  "name": "duskkeep-fronts",
  "version": "0.25.163",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "check:full": "npm run check && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:reset": "node scripts/reset.mjs",
    "screenshots": "node scripts/capture-screens.mjs",
    "screenshots:auto": "node scripts/capture-screens.mjs --start-server",
    "audio:sfx": "node scripts/audio/generate-elevenlabs-sfx.mjs",
    "audio:music": "node scripts/audio/generate-elevenlabs-music.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "clsx": "2.1.1",
    "next": "^16.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "2.3.0",
    "zod": "3.23.8",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5",
    "vitest": "^4.1.5"
  }
}
